{
    "require": {
        "vlucas/valitron": "^1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "src/Core/",
            "Controllers\\": "src/Controllers/",
            "Models\\": "src/Models/",
